@page
@model ProyectoRH2025.Pages.Sellos.GestionSellosModel
@{
    ViewData["Title"] = "Gestión de Sellos";
}

<style>
    :root {
        --primary-green: #16a34a;
        --primary-purple: #7c3aed;
        --primary-blue: #2563eb;
        --primary-orange: #ea580c;
        --primary-pink: #ec4899;
        --shadow-sm: 0 2px 8px rgba(0,0,0,0.08);
        --shadow-md: 0 4px 16px rgba(0,0,0,0.12);
        --shadow-lg: 0 8px 32px rgba(0,0,0,0.16);
    }

    body {
        background: #f8f9fa;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    }

    .dashboard-header {
        background: white;
        padding: 2rem 0;
        margin-bottom: 2rem;
        box-shadow: var(--shadow-sm);
    }

    .dashboard-title {
        font-size: 2rem;
        font-weight: 700;
        color: #1f2937;
        margin: 0;
        text-transform: uppercase;
        letter-spacing: -0.5px;
    }

    .stats-container {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    .stat-card {
        background: white;
        border-radius: 16px;
        padding: 2rem;
        box-shadow: var(--shadow-md);
        position: relative;
        overflow: hidden;
        transition: transform 0.2s, box-shadow 0.2s;
    }

        .stat-card:hover {
            transform: translateY(-4px);
            box-shadow: var(--shadow-lg);
        }

        .stat-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 6px;
        }

        .stat-card.green::before {
            background: var(--primary-green);
        }

        .stat-card.purple::before {
            background: var(--primary-purple);
        }

        .stat-card.blue::before {
            background: var(--primary-blue);
        }

    .stat-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        margin-bottom: 1rem;
        color: white;
    }

        .stat-icon.green {
            background: var(--primary-green);
        }

        .stat-icon.purple {
            background: var(--primary-purple);
        }

        .stat-icon.blue {
            background: var(--primary-blue);
        }

    .stat-label {
        font-size: 0.875rem;
        color: #6b7280;
        font-weight: 600;
        text-transform: uppercase;
        margin-bottom: 0.5rem;
        letter-spacing: 0.5px;
    }

    .stat-value {
        font-size: 2.5rem;
        font-weight: 700;
        color: #1f2937;
        line-height: 1;
    }

    .actions-container {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 1rem;
        margin-bottom: 2rem;
    }

    .action-btn {
        background: white;
        border: none;
        border-radius: 12px;
        padding: 1.5rem;
        box-shadow: var(--shadow-md);
        cursor: pointer;
        transition: all 0.2s;
        text-decoration: none;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.75rem;
        color: white;
        font-weight: 600;
        font-size: 0.9rem;
    }

        .action-btn:hover {
            transform: translateY(-4px);
            box-shadow: var(--shadow-lg);
        }

        .action-btn.green {
            background: linear-gradient(135deg, #16a34a 0%, #15803d 100%);
        }

        .action-btn.blue {
            background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
        }

        .action-btn.orange {
            background: linear-gradient(135deg, #ea580c 0%, #c2410c 100%);
        }

        .action-btn.purple {
            background: linear-gradient(135deg, #7c3aed 0%, #6d28d9 100%);
        }

        .action-btn.pink {
            background: linear-gradient(135deg, #ec4899 0%, #db2777 100%);
        }

    .action-icon {
        font-size: 2rem;
    }

    .tables-container {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(500px, 1fr));
        gap: 1.5rem;
    }

    .table-card {
        background: white;
        border-radius: 16px;
        box-shadow: var(--shadow-md);
        overflow: hidden;
    }

    .table-header {
        background: #f9fafb;
        padding: 1.25rem 1.5rem;
        border-bottom: 2px solid #e5e7eb;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .table-title {
        font-size: 1.125rem;
        font-weight: 700;
        color: #1f2937;
        margin: 0;
        text-transform: uppercase;
    }

    .download-btn {
        background: #e5e7eb;
        border: none;
        border-radius: 8px;
        width: 36px;
        height: 36px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: #6b7280;
    }

        .download-btn:hover {
            background: #d1d5db;
        }

    .modern-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
    }

        .modern-table thead {
            background: #f9fafb;
        }

        .modern-table th {
            padding: 1rem 1.5rem;
            text-align: left;
            font-size: 0.75rem;
            font-weight: 700;
            color: #6b7280;
            text-transform: uppercase;
            border-bottom: 1px solid #e5e7eb;
        }

        .modern-table td {
            padding: 1rem 1.5rem;
            border-bottom: 1px solid #f3f4f6;
            color: #374151;
            font-size: 0.9rem;
        }

        .modern-table tbody tr:hover {
            background: #f9fafb;
        }

    .status-badge {
        display: inline-block;
        padding: 0.375rem 0.875rem;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: capitalize;
    }

        .status-badge.available {
            background: #d1fae5;
            color: #065f46;
        }

        .status-badge.assigned {
            background: #dbeafe;
            color: #1e40af;
        }

        .status-badge.pending {
            background: #fef3c7;
            color: #92400e;
        }

    .modal-content {
        border: none;
        border-radius: 16px;
        box-shadow: var(--shadow-lg);
    }

    .modal-header {
        border-bottom: 2px solid #e5e7eb;
        padding: 1.5rem;
    }

    .modal-title {
        font-weight: 700;
        color: #1f2937;
    }

    .form-label {
        font-weight: 600;
        color: #374151;
        margin-bottom: 0.5rem;
        font-size: 0.875rem;
    }

    .form-control, .form-select {
        border: 2px solid #e5e7eb;
        border-radius: 8px;
        padding: 0.75rem;
        transition: border-color 0.2s;
    }

        .form-control:focus, .form-select:focus {
            border-color: var(--primary-blue);
            box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
        }

    .btn-modern {
        padding: 0.75rem 1.5rem;
        border-radius: 8px;
        font-weight: 600;
        border: none;
        transition: all 0.2s;
    }

        .btn-modern:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
        }

        .btn-modern.green {
            background: var(--primary-green);
            color: white;
        }

        .btn-modern.blue {
            background: var(--primary-blue);
            color: white;
        }

        .btn-modern.orange {
            background: var(--primary-orange);
            color: white;
        }

        .btn-modern.purple {
            background: var(--primary-purple);
            color: white;
        }

        .btn-modern.pink {
            background: var(--primary-pink);
            color: white;
        }

    .alert-modern {
        border: none;
        border-radius: 12px;
        padding: 1rem 1.5rem;
        box-shadow: var(--shadow-sm);
    }

    .sello-checkbox {
        width: 18px;
        height: 18px;
        cursor: pointer;
    }

    .modern-table tbody tr:has(.sello-checkbox:checked) {
        background: #fef3c7 !important;
    }

    .btn-danger, .btn-success {
        font-weight: 600;
        padding: 0.5rem 1rem;
        border: none;
        transition: all 0.2s;
        color: white;
    }

    .btn-danger {
        background: linear-gradient(135deg, #ea580c 0%, #c2410c 100%);
    }

    .btn-success {
        background: linear-gradient(135deg, #16a34a 0%, #15803d 100%);
    }

        .btn-danger.disabled, .btn-success.disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }

    .feedback-valid {
        color: #16a34a;
        font-size: 0.875rem;
        font-weight: 600;
    }

    .feedback-invalid {
        color: #ea580c;
        font-size: 0.875rem;
        font-weight: 600;
    }
</style>

<div class="dashboard-header">
    <div class="container">
        <h1 class="dashboard-title">📦 Gestión de Sellos - Dashboard</h1>
    </div>
</div>

<div class="container">
    @if (TempData["MensajeExito"] != null)
    {
        <div class="alert alert-success alert-modern alert-dismissible fade show">
            <i class="fas fa-check-circle me-2"></i> @TempData["MensajeExito"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["MensajeError"] != null)
    {
        <div class="alert alert-danger alert-modern alert-dismissible fade show">
            <i class="fas fa-exclamation-circle me-2"></i> @TempData["MensajeError"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="stats-container">
        <div class="stat-card green">
            <div class="stat-icon green"><i class="fas fa-shield-alt"></i></div>
            <div class="stat-label">Total de Sellos</div>
            <div class="stat-value">@Model.ListaSellos.Count</div>
        </div>
        <div class="stat-card purple">
            <div class="stat-icon purple"><i class="fas fa-check-circle"></i></div>
            <div class="stat-label">Sellos Central (Disp)</div>
            <div class="stat-value">@Model.ListaSellos.Count(s => s.Status == 1)</div>
        </div>
        <div class="stat-card blue">
            <div class="stat-icon blue"><i class="fas fa-building"></i></div>
            <div class="stat-label">Sellos en Cuentas</div>
            <div class="stat-value">@Model.ListaSellos.Count(s => s.Status == 14)</div>
        </div>
    </div>

    <div class="actions-container">
        <button class="action-btn green" data-bs-toggle="modal" data-bs-target="#importModal">
            <div class="action-icon">🏛️</div>
            <div>IMPORTAR SELLOS</div>
        </button>

        <button class="action-btn blue" data-bs-toggle="modal" data-bs-target="#assignModal">
            <div class="action-icon">🔄</div>
            <div>ASIGNAR A CUENTA</div>
        </button>

        <button class="action-btn orange" data-bs-toggle="modal" data-bs-target="#unassignModal">
            <div class="action-icon">❌</div>
            <div>DEVOLVER DE CUENTA</div>
        </button>

        <button class="action-btn pink" data-bs-toggle="modal" data-bs-target="#addSelloManualModal">
            <div class="action-icon">➕</div>
            <div>AGREGAR MANUAL</div>
        </button>

        <button class="action-btn purple" onclick="window.location.href='/Sellos/HistorialSellos'">
            <div class="action-icon">📊</div>
            <div>VER HISTORIAL</div>
        </button>
    </div>

    <div class="tables-container">
        <div class="table-card">
            <div class="table-header">
                <h3 class="table-title">Sellos Central (@Model.ListaSellos.Count(s => s.Status == 1))</h3>
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-sm btn-success disabled" onclick="asignarSeleccionadosDisponibles()">
                        <i class="fas fa-check-circle me-1"></i> Asignar a Cuenta
                    </button>
                    <button class="download-btn" onclick="downloadAvailable()"><i class="fas fa-download"></i></button>
                </div>
            </div>
            <div class="table-responsive">
                <form id="formAsignarSeleccionados" method="post" asp-page-handler="AsignarSeleccionados">
                    <table class="modern-table">
                        <thead>
                            <tr>
                                <th width="50" class="text-center">
                                    <input type="checkbox" id="selectAllAvailable" onclick="toggleSelectAllAvailable(this)" title="Seleccionar todos">
                                </th>
                                <th>Sello</th>
                                <th>Fecha Alta</th>
                                <th>Recibió</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.ListaSellos.Any(s => s.Status == 1))
                            {
                                @foreach (var item in Model.ListaSellos.Where(s => s.Status == 1))
                                {
                                    <tr>
                                        <td class="text-center">
                                            <input type="checkbox" name="SellosSeleccionados" value="@item.Id" class="sello-checkbox sello-checkbox-available form-check-input" />
                                        </td>
                                        <td class="fw-bold">@item.Sello</td>
                                        <td>@(item.Fentrega?.ToString("dd/MM/yyyy") ?? "-")</td>
                                        <td>@(item.Recibio ?? "-")</td>
                                        <td><span class="status-badge available">En Central</span></td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center text-muted py-4">
                                        <i class="fas fa-inbox fa-2x mb-2"></i>
                                        <div>No hay sellos disponibles en central</div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </form>
            </div>
        </div>

        <div class="table-card">
            <div class="table-header">
                <h3 class="table-title">Sellos en Cuentas (@Model.ListaSellos.Count(s => s.Status == 14))</h3>
                <div class="d-flex gap-2">
                    <button class="btn btn-sm btn-danger disabled" onclick="desasignarSeleccionados()" style="border-radius: 8px;">
                        <i class="fas fa-undo-alt me-1"></i> Devolver a Central
                    </button>
                    <button class="download-btn" onclick="downloadAssigned()"><i class="fas fa-download"></i></button>
                </div>
            </div>
            <div class="table-responsive">
                <form id="formDesasignarSeleccionados" method="post" asp-page-handler="DesasignarSeleccionados">
                    <table class="modern-table">
                        <thead>
                            <tr>
                                <th width="50" class="text-center">
                                    <input type="checkbox" id="selectAllAssigned" onclick="toggleSelectAllAssigned(this)" title="Seleccionar todos">
                                </th>
                                <th>Sello</th>
                                <th>Cuenta Actual</th>
                                <th>Fecha Asignación</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.ListaSellos.Any(s => s.Status == 14))
                            {
                                @foreach (var item in Model.ListaSellos.Where(s => s.Status == 14))
                                {
                                    <tr>
                                        <td class="text-center">
                                            <input type="checkbox" name="SellosSeleccionados" value="@item.Id" class="sello-checkbox sello-checkbox-assigned form-check-input">
                                        </td>
                                        <td class="fw-bold">@item.Sello</td>
                                        <td>
                                            @(item.Cuenta?.NombreCuenta ?? "Sin asignar")
                                        </td>
                                        <td>@(item.FechaAsignacion?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                                        <td><span class="status-badge assigned">En Local</span></td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center text-muted py-4">
                                        <i class="fas fa-building fa-2x mb-2"></i>
                                        <div>Ninguna cuenta tiene sellos asignados</div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="assignModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">🔄 Enviar Sellos a Cuenta (Inventario Local)</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form method="post" asp-page-handler="Asignar">
                    <div class="mb-3">
                        <label class="form-label">Seleccionar Cuenta</label>
                        <select asp-for="CuentaSeleccionadaId" asp-items="Model.ListaCuentas" class="form-select">
                            <option value="">-- Seleccionar Cuenta Destino --</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Cantidad de Sellos</label>
                        <input asp-for="CantidadAsignar" type="number" min="1" class="form-control" placeholder="Ingresa la cantidad" />
                    </div>
                    <div class="alert alert-info alert-modern">
                        <i class="fas fa-info-circle me-2"></i>
                        <small>El sistema tomará sellos del almacén central y los pasará a la cuenta seleccionada.</small>
                    </div>
                    <button type="submit" class="btn btn-modern blue w-100">
                        <i class="fas fa-random me-2"></i> Traspasar Automáticamente
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="importModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">🏛️ Importar Sellos a Central (Excel)</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form method="post" enctype="multipart/form-data" asp-page-handler="Importar">
                    <div class="mb-3">
                        <label class="form-label">Archivo Excel (.xlsx)</label>
                        <input type="file" asp-for="ArchivoExcel" class="form-control" accept=".xlsx, .xls" />
                        <small class="text-muted">Formato: Columna 1: Número Sello | Columna 2: Fecha | Columna 3: Recibió</small>
                    </div>
                    <div class="alert alert-info py-2">
                        <small>Los sellos se guardarán directamente en el inventario Central como Disponibles.</small>
                    </div>
                    <button type="submit" class="btn btn-modern green w-100">
                        <i class="fas fa-upload me-2"></i> Subir e Importar
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="unassignModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">❌ Devolver Sellos a Almacén Central</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form method="post" asp-page-handler="DesasignarPorCuenta">
                    <div class="mb-3">
                        <label class="form-label">Seleccionar Cuenta</label>
                        <select asp-for="CuentaADesasignar" asp-items="Model.ListaCuentas" class="form-select">
                            <option value="">-- Seleccionar Cuenta Origen --</option>
                        </select>
                    </div>
                    <div class="alert alert-warning alert-modern">
                        <i class="fas fa-exclamation-triangle me-2"></i>
                        <small>Se devolverán TODOS los sellos físicos de esta cuenta hacia el almacén central (Status 1).</small>
                    </div>
                    <button type="submit" class="btn btn-modern orange w-100">
                        <i class="fas fa-undo-alt me-2"></i> Devolver Todos
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="addSelloManualModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">➕ Agregar Sello Manual a Central</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="formAgregarSelloManual" method="post" asp-page-handler="AgregarSelloManual">
                    <div class="mb-3 position-relative">
                        <label class="form-label">Número de Sello *</label>
                        <input type="text" id="inputNumeroSello" name="NumeroSello" class="form-control"
                               placeholder="Ej: 123456" maxlength="20" required autocomplete="off" />
                        <div id="feedbackSello" class="mt-1"></div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Fecha de Entrega (opcional)</label>
                        <input type="date" id="inputFechaEntrega" name="FechaEntregaManual" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Recibió (opcional)</label>
                        <input type="text" id="inputRecibio" name="RecibioManual" class="form-control"
                               placeholder="Nombre o código" maxlength="100" />
                    </div>

                    <div class="alert alert-info alert-modern mt-3">
                        <i class="fas fa-info-circle me-2"></i>
                        El sello se agregará al inventario central como <strong>Disponible (Status 1)</strong>.
                    </div>

                    <button type="submit" id="btnGuardarSelloManual" class="btn btn-modern pink w-100" disabled>
                        <i class="fas fa-plus me-2"></i> Agregar Sello
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        // Checkboxes Disponibles
        function toggleSelectAllAvailable(checkbox) {
            const checkboxes = document.querySelectorAll('.sello-checkbox-available');
            checkboxes.forEach(cb => cb.checked = checkbox.checked);
            actualizarContadorDisponibles();
        }

        // Checkboxes Asignados
        function toggleSelectAllAssigned(checkbox) {
            const checkboxes = document.querySelectorAll('.sello-checkbox-assigned');
            checkboxes.forEach(cb => cb.checked = checkbox.checked);
            actualizarContadorAsignados();
        }

        // Actualizar botón "Asignar Seleccionados"
        function actualizarContadorDisponibles() {
            const checkboxes = document.querySelectorAll('.sello-checkbox-available:checked');
            const container = document.querySelector('.table-card:has(.sello-checkbox-available)');
            const botonAsignar = container ? container.querySelector('.btn-success') : null;

            if (botonAsignar) {
                if (checkboxes.length > 0) {
                    botonAsignar.innerHTML = `<i class="fas fa-check-circle me-1"></i> Asignar a Cuenta (${checkboxes.length})`;
                    botonAsignar.classList.remove('disabled');
                } else {
                    botonAsignar.innerHTML = '<i class="fas fa-check-circle me-1"></i> Asignar a Cuenta';
                    botonAsignar.classList.add('disabled');
                }
            }
        }

        // Actualizar botón "Desasignar Seleccionados"
        function actualizarContadorAsignados() {
            const checkboxes = document.querySelectorAll('.sello-checkbox-assigned:checked');
            const container = document.querySelector('.table-card:has(.sello-checkbox-assigned)');
            const botonDesasignar = container ? container.querySelector('.btn-danger') : null;

            if (botonDesasignar) {
                if (checkboxes.length > 0) {
                    botonDesasignar.innerHTML = `<i class="fas fa-undo-alt me-1"></i> Devolver (${checkboxes.length})`;
                    botonDesasignar.classList.remove('disabled');
                } else {
                    botonDesasignar.innerHTML = '<i class="fas fa-undo-alt me-1"></i> Devolver a Central';
                    botonDesasignar.classList.add('disabled');
                }
            }
        }

        document.addEventListener('DOMContentLoaded', function () {
            // Disponibles
            const checkboxesAvailable = document.querySelectorAll('.sello-checkbox-available');
            const selectAllAvailable = document.getElementById('selectAllAvailable');
            checkboxesAvailable.forEach(cb => {
                cb.addEventListener('change', function () {
                    const all = Array.from(checkboxesAvailable).every(c => c.checked);
                    const some = Array.from(checkboxesAvailable).some(c => c.checked);
                    if (selectAllAvailable) {
                        selectAllAvailable.checked = all;
                        selectAllAvailable.indeterminate = some && !all;
                    }
                    actualizarContadorDisponibles();
                });
            });

            // Asignados
            const checkboxesAssigned = document.querySelectorAll('.sello-checkbox-assigned');
            const selectAllAssigned = document.getElementById('selectAllAssigned');
            checkboxesAssigned.forEach(cb => {
                cb.addEventListener('change', function () {
                    const all = Array.from(checkboxesAssigned).every(c => c.checked);
                    const some = Array.from(checkboxesAssigned).some(c => c.checked);
                    if (selectAllAssigned) {
                        selectAllAssigned.checked = all;
                        selectAllAssigned.indeterminate = some && !all;
                    }
                    actualizarContadorAsignados();
                });
            });
        });

        // Lógica SweetAlert para Asignar
        function asignarSeleccionadosDisponibles() {
            const form = document.getElementById('formAsignarSeleccionados');
            const checkboxes = document.querySelectorAll('.sello-checkbox-available:checked');

            if (checkboxes.length === 0) return;

            let sellosTexto = '';
            checkboxes.forEach((cb, index) => {
                const fila = cb.closest('tr');
                const numeroSello = fila.querySelector('td:nth-child(2)').textContent.trim();
                sellosTexto += numeroSello + (index < checkboxes.length - 1 ? ', ' : '');
            });

            Swal.fire({
                title: '¿Enviar a inventario local?',
                html: `
                    <div class="text-start">
                        <p>Vas a mandar <strong>${checkboxes.length}</strong> sello(s):</p>
                        <div class="alert alert-info" style="max-height: 100px; overflow-y: auto;">${sellosTexto}</div>
                        <p>Selecciona la Cuenta destino:</p>
                        <select id="cuentaSelect" class="form-select mt-2">
                            <option value="">-- Seleccionar Cuenta --</option>
                            @foreach (var c in Model.ListaCuentas)
                            {
                                        <text><option value="@c.Value">@c.Text</option></text>
                            }
                        </select>
                    </div>
                `,
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#16a34a',
                cancelButtonColor: '#6b7280',
                confirmButtonText: 'Sí, mandar a cuenta',
                cancelButtonText: 'Cancelar',
                preConfirm: () => {
                    const cuentaId = document.getElementById('cuentaSelect').value;
                    if (!cuentaId) {
                        Swal.showValidationMessage('Debes seleccionar una cuenta destino');
                        return false;
                    }
                    return cuentaId;
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    let hiddenInput = document.createElement('input');
                    hiddenInput.type = 'hidden';
                    hiddenInput.name = 'CuentaSeleccionadaId';
                    hiddenInput.value = result.value;
                    form.appendChild(hiddenInput);
                    form.submit();
                }
            });
        }

        // Lógica SweetAlert para Desasignar
        function desasignarSeleccionados() {
            const form = document.getElementById('formDesasignarSeleccionados');
            const checkboxes = document.querySelectorAll('.sello-checkbox-assigned:checked');

            if (checkboxes.length === 0) return;

            Swal.fire({
                title: '¿Devolver a Central?',
                text: `Se regresarán ${checkboxes.length} sellos locales hacia el almacén central.`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ea580c',
                cancelButtonColor: '#6b7280',
                confirmButtonText: 'Sí, devolver',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    form.submit();
                }
            });
        }

        function downloadAvailable() { alert('Descargando lista de sellos en central...'); }
        function downloadAssigned() { alert('Descargando lista de sellos en cuentas locales...'); }

        const inputSello = document.getElementById('inputNumeroSello');
        const feedback = document.getElementById('feedbackSello');
        const btnGuardar = document.getElementById('btnGuardarSelloManual');

        if (inputSello) {
            let timeoutValida;
            inputSello.addEventListener('input', function () {
                clearTimeout(timeoutValida);
                const valor = this.value.trim();

                feedback.innerHTML = '';
                btnGuardar.disabled = true;

                if (valor.length < 3) return;

                timeoutValida = setTimeout(async () => {
                    try {
                        const url = `/Sellos/GestionSellos?handler=CheckSello&numeroSelloCheck=${encodeURIComponent(valor)}`;
                        const response = await fetch(url);

                        if (!response.ok) throw new Error('Network response was not ok');

                        const data = await response.json();

                        if (data.existe) {
                            feedback.innerHTML = `
                                <span class="feedback-invalid">
                                    <i class="fas fa-times-circle me-1"></i> ${data.mensaje}
                                </span>`;
                            btnGuardar.disabled = true;
                        } else {
                            feedback.innerHTML = `
                                <span class="feedback-valid">
                                    <i class="fas fa-check-circle me-1"></i> ${data.mensaje}
                                </span>`;
                            btnGuardar.disabled = false;
                        }
                    } catch (err) {
                        console.error(err);
                        feedback.innerHTML = '<span class="text-danger small">Error al verificar disponibilidad</span>';
                        btnGuardar.disabled = true;
                    }
                }, 500);
            });
        }
    </script>
}