@page
@model ProyectoRH2025.Pages.Sellos.AsignarOperadorModel
@{
    ViewData["Title"] = "Asignar Sello a Operador";
}

<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Asignar Sello a Operador</h5>
        </div>
        <div class="card-body">
            <form method="post" id="formAsignar">
                <div class="mb-3">
                    <label class="form-label">Sello disponible <span class="text-danger">*</span></label>
                    <select asp-for="IdSello" class="form-select sello-select" required>
                        <option value="" data-idcuenta="">-- Seleccionar Sello --</option>
                        @if (!Model.SellosList.Any())
                        {
                            <option value="" disabled>-- No tienes sellos en inventario --</option>
                        }
                        @foreach (var s in Model.SellosList)
                        {
                            <option value="@s.Id" data-idcuenta="@s.IdCuenta">@s.Sello (Cuenta: @s.NombreCuenta)</option>
                        }
                    </select>
                    <span asp-validation-for="IdSello" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Tipo de Asignación <span class="text-danger">*</span></label>
                    <select asp-for="TipoAsignacion" asp-items="Model.TiposAsignacion" class="form-select" id="TipoAsignacion" required></select>
                    <span asp-validation-for="TipoAsignacion" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Operador principal <span class="text-danger">*</span></label>
                    <select asp-for="IdOperador" asp-items="Model.Operadores" class="form-select operador-select" required></select>
                    <span asp-validation-for="IdOperador" class="text-danger"></span>
                </div>

                <div class="mb-3" id="segundo-operador-container" style="display: none;">
                    <label class="form-label">Segundo operador (opcional)</label>
                    <select asp-for="IdOperador2" asp-items="Model.Operadores" class="form-select operador-select"></select>
                </div>

                <div class="mb-3">
                    <label class="form-label">Unidad <span class="text-danger">*</span></label>
                    <select asp-for="IdUnidad" class="form-select unidad-select" required>
                        <option value="">-- Seleccionar Unidad --</option>
                        @if (!Model.UnidadesList.Any())
                        {
                            <option value="" disabled>-- No tienes unidades asignadas --</option>
                        }
                        @foreach (var u in Model.UnidadesList)
                        {
                            var textoUnidad = string.IsNullOrEmpty(u.Placas) ? $"Unidad {u.NumUnidad}" : $"Unidad {u.NumUnidad} - {u.Placas}";
                            <option value="@u.Id" data-idcuenta="@u.IdCuenta">@textoUnidad</option>
                        }
                    </select>
                    <span asp-validation-for="IdUnidad" class="text-danger"></span>
                    <small class="form-text text-muted text-info" id="infoFiltroUnidad">
                        <i class="fas fa-info-circle"></i> Las unidades se filtrarán automáticamente al seleccionar un sello.
                    </small>
                </div>

                <div class="mb-3">
                    <label class="form-label">Ruta <span class="text-danger">*</span></label>
                    <input asp-for="Ruta" class="form-control" required />
                    <span asp-validation-for="Ruta" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Caja <span class="text-danger">*</span></label>
                    <input asp-for="Caja" class="form-control" required />
                    <span asp-validation-for="Caja" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Comentarios</label>
                    <textarea asp-for="Comentarios" class="form-control" rows="3"></textarea>
                </div>

                <button type="submit" class="btn btn-success">
                    <i class="fas fa-check-circle"></i> Asignar Sello
                </button>
            </form>

            @if (!string.IsNullOrEmpty(Model.Mensaje))
            {
                <div class="alert @(Model.Mensaje.StartsWith("✅") ? "alert-success" : "alert-danger") d-flex align-items-center mt-4" role="alert">
                    <i class="fas @(Model.Mensaje.StartsWith("✅") ? "fa-check-circle" : "fa-exclamation-triangle") me-2"></i>
                    <div>@Model.Mensaje</div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <script>
        $(document).ready(function () {

            // ✅ 1. Almacenamos TODAS las unidades enviadas desde el backend en una variable de JS
            var todasLasUnidades = [
                @foreach (var u in Model.UnidadesList)
                {
                        var texto = string.IsNullOrEmpty(u.Placas) ? $"Unidad {u.NumUnidad}" : $"Unidad {u.NumUnidad} - {u.Placas}";
                        <text>{ id: '@u.Id', idCuenta: '@u.IdCuenta', texto: '@texto' },</text>
                }
            ];

            // Limpiar formulario si hubo éxito
            var mensajeExito = '@Html.Raw(Model.MensajeExito ?? "")';
            if (mensajeExito === 'true') {
                limpiarFormulario();
            }

            // Activar Select2
            $('.sello-select, .operador-select, .unidad-select').select2({
                width: '100%',
                placeholder: "Buscar..."
            });

            // ✅ 2. LÓGICA DE FILTRADO DINÁMICO
            $('#IdSello').on('change', function() {
                var selectedOption = $(this).find('option:selected');
                var idCuentaSello = selectedOption.data('idcuenta');

                var selectUnidad = $('#IdUnidad');
                var currentVal = selectUnidad.val(); // Guardar la unidad actual seleccionada (si la hay)

                // Vaciamos el dropdown de unidades
                selectUnidad.empty();
                selectUnidad.append(new Option('-- Seleccionar Unidad --', ''));

                let unidadesEncontradas = 0;

                // Lo volvemos a llenar solo con las que coinciden en IdCuenta
                todasLasUnidades.forEach(function(u) {
                    if (!idCuentaSello || u.idCuenta === idCuentaSello.toString()) {
                        selectUnidad.append(new Option(u.texto, u.id));
                        unidadesEncontradas++;
                    }
                });

                // Si la unidad que tenía seleccionada sigue siendo válida, la recuperamos
                if (selectUnidad.find("option[value='" + currentVal + "']").length > 0) {
                    selectUnidad.val(currentVal);
                }

                // Refrescar Select2
                selectUnidad.trigger('change.select2');

                // Actualizar mensaje de interfaz
                if(idCuentaSello) {
                    $('#infoFiltroUnidad').html(`<i class="fas fa-check-circle"></i> Filtrado: <strong>${unidadesEncontradas}</strong> unidades vinculadas a esta cuenta.`);
                    $('#infoFiltroUnidad').removeClass('text-info text-danger').addClass(unidadesEncontradas > 0 ? 'text-success' : 'text-danger');
                } else {
                    $('#infoFiltroUnidad').html(`<i class="fas fa-info-circle"></i> Las unidades se filtrarán automáticamente al seleccionar un sello.`);
                    $('#infoFiltroUnidad').removeClass('text-success text-danger').addClass('text-info');
                }
            });

            // Mostrar u ocultar segundo operador si es comboy
            $('#TipoAsignacion').on('change', function () {
                const tipo = parseInt($(this).val());
                $('#segundo-operador-container').toggle(tipo === 1);
            }).trigger('change');

            // Validar form submit
            $('#formAsignar').on('submit', function (e) {
                const tipo = parseInt($('#TipoAsignacion').val());
                const op1 = $('#IdOperador').val();
                const op2 = $('#IdOperador2').val();

                if (tipo === 1 && op1 && op2 && op1 === op2) {
                    e.preventDefault();
                    alert("❌ No puedes seleccionar el mismo operador dos veces en Comboy.");
                    return false;
                }

                if (!$('#IdSello').val() || !$('#TipoAsignacion').val() ||
                    !$('#IdOperador').val() || !$('#IdUnidad').val() ||
                    !$('#Ruta').val().trim() || !$('#Caja').val().trim()) {
                    alert("❌ Por favor completa todos los campos obligatorios marcados con *");
                    return false;
                }
            });

            function limpiarFormulario() {
                $('#IdSello').val('').trigger('change');
                $('#TipoAsignacion').val('').trigger('change');
                $('#IdOperador').val('').trigger('change');
                $('#IdOperador2').val('').trigger('change');
                $('#IdUnidad').val('').trigger('change');
                $('#Ruta').val('');
                $('#Caja').val('');
                $('#Comentarios').val('');
                $('#segundo-operador-container').hide();
            }
        });
    </script>
}