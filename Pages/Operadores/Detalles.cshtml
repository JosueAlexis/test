                                        <dd class="col-sm-7 fw-bold font-monospace">@Model.CamposAkna.VisaLaserNumero</dd>

                                        @if (Model.CamposAkna.VisaLaserVigencia.HasValue)
                                        {
                                            var dias = (Model.CamposAkna.VisaLaserVigencia.Value - DateTime.Today).Days;
                                            var badge = dias < 30 ? "bg-danger" : dias < 90 ? "bg-warning text-dark" : "bg-success";
