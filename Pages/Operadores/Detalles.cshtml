                                            <dd class="col-sm-7">
                                                @Model.CamposAkna.FastVigencia.Value.ToString("dd/MM/yyyy")
                                                <span class="badge @badge ms-2">@dias días</span>
                                            </dd>
                                        }
                                    </dl>
                                }
                                else
                                {
                                    <p class="text-center text-muted my-4 fst-italic">
                                        <i class="fas fa-info-circle me-2"></i>Sin información de FAST
