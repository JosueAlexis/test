@functions {
    static Microsoft.AspNetCore.Html.IHtmlContent BooleanoLabel(bool? valor)
    {
        return valor switch
        {
            true => new Microsoft.AspNetCore.Html.HtmlString("<span class='text-success fw-bold'>Sí</span>"),
            false => new Microsoft.AspNetCore.Html.HtmlString("<span class='text-muted'>No</span>"),
            _ => new Microsoft.AspNetCore.Html.HtmlString("<span class='text-muted small'>—</span>")
        };
    }

    static string FormatearEnum<T>(T? valor) where T : struct, Enum
    {
        if (valor == null) return "—";
        string texto = valor.ToString();
        return System.Text.RegularExpressions.Regex.Replace(texto, "([a-z])([A-Z])", "$1 $2");
    }

    static string FormatearEscolaridad(ProyectoRH2025.Models.Enums.Escolaridad? esc)
    {
        return esc switch
        {
            ProyectoRH2025.Models.Enums.Escolaridad.TecnicoBachillerato => "Técnico / Bachillerato tecnológico",
            null => "—",
            _ => FormatearEnum(esc)
        };
    }
}
