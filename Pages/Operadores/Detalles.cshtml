                                    @if (!string.IsNullOrEmpty(Model.PolizaVida.NombreBeneficiario))
                                    {
                                        <dt class="col-sm-5 text-muted">Beneficiario:</dt>
                                        <dd class="col-sm-7">@Model.PolizaVida.NombreBeneficiario</dd>
                                    }

                                    @if (!string.IsNullOrEmpty(Model.PolizaVida.Parentesco))
                                    {
                                        <dt class="col-sm-5 text-muted">Parentesco:</dt>
                                        <dd class="col-sm-7">@Model.PolizaVida.Parentesco</dd>
                                    }

                                    @if (Model.PolizaVida.Porcentaje.HasValue)
                                    {
                                        <dt class="col-sm-5 text-muted">Porcentaje:</dt>
