                                        <dd class="col-sm-7 small">@Model.PolizaVida.Direccion</dd>
                                    }
                                </dl>
                            }
                            else
                            {
                                <p class="text-center text-muted my-4 fst-italic">
                                    <i class="fas fa-info-circle me-2"></i>Sin información de póliza de vida
                                </p>
                            }
                        </div>
                    </div>
                </div>

                <!-- 9 - DATOS BANORTE -->
                <div class="col-lg-6">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-header" style="background: linear-gradient(135deg, #e31e24 0%, #b91419 100%); color: white;">
                            <h5 class="mb-0"><i class="fas fa-university me-2"></i>Banorte</h5>
                        </div>
                        <div class="card-body">
                            @if (Model.Banorte != null && !string.IsNullOrEmpty(Model.Banorte.NumCuenta))
                            {
                                <dl class="row mb-0 small">
                                    <dt class="col-sm-5 text-muted">Num. Cuenta:</dt>
                                    <dd class="col-sm-7 fw-bold">@Model.Banorte.NumCuenta</dd>

                                    @if (!string.IsNullOrEmpty(Model.Banorte.CLABE))
                                    {
                                        <dt class="col-sm-5 text-muted">CLABE:</dt>
                                        <dd class="col-sm-7 font-monospace">@Model.Banorte.CLABE</dd>
                                    }

                                    @if (!string.IsNullOrEmpty(Model.Banorte.NumTarjeta))
                                    {
                                        <dt class="col-sm-5 text-muted">Tarjeta:</dt>
                                        <dd class="col-sm-7 font-monospace">@Model.Banorte.NumTarjeta</dd>
                                    }

                                    @if (!string.IsNullOrEmpty(Model.Banorte.NombreBeneficiario))
                                    {
                                        <dt class="col-sm-12 text-muted border-top pt-2 mt-2"><strong>Beneficiario:</strong></dt>
                                        <dt class="col-sm-5 text-muted ps-3">Nombre:</dt>
                                        <dd class="col-sm-7">@Model.Banorte.NombreBeneficiario</dd>

