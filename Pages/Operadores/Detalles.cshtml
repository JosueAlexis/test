@page "{id:int}"
@model ProyectoRH2025.Pages.Operadores.DetallesModel
@{
    ViewData["Title"] = "Detalles del Empleado";
    var esBaja = !string.IsNullOrEmpty(Model.FechaEgresoFormateada);
    var nombre = !string.IsNullOrEmpty(Model.Empleado?.Names) && !string.IsNullOrEmpty(Model.Empleado?.Apellido)
        ? $"{Model.Empleado.Names} {Model.Empleado.Apellido}".Trim()
        : Model.Empleado?.Names ?? "—";
}

<div class="container-fluid py-4 px-3 px-md-4">
    <div class="row align-items-center mb-5 g-4">
        <div class="col-auto">
            <div class="photo-frame">
                @if (!string.IsNullOrEmpty(Model.ImagenBase64))
                {
                    <img src="data:image/jpeg;base64,@Model.ImagenBase64"
                         class="rounded-circle shadow-lg img-thumbnail"
                         alt="@nombre"
                         style="width:150px; height:150px; object-fit:cover; border:5px solid #fff;" />
                }
                else
                {
                    <div class="rounded-circle bg-light shadow-lg d-flex align-items-center justify-content-center text-muted"
                         style="width:150px; height:150px; font-size:4rem;">
                        <i class="fas fa-user"></i>
                    </div>
                }
            </div>
        </div>
        <div class="col">
            <h2 class="fw-bold mb-1 text-dark">@nombre</h2>
            <p class="text-primary fs-5 mb-2 fw-medium">
                @(Model.NombrePuesto ?? "—") • @(Model.NombreCliente ?? "—")
            </p>
            @if (esBaja)
            {
                <span class="badge bg-danger fs-6 px-3 py-2">
                    <i class="fas fa-user-slash me-2"></i>BAJA: @Model.FechaEgresoFormateada
                </span>
            }
            else
            {
                <span class="badge bg-success fs-6 px-3 py-2">
                    <i class="fas fa-check-circle me-2"></i>ACTIVO
                </span>
            }

            <div class="float-end mt-2 d-flex gap-2">
                <a href="/Operadores/EditarBasico/@Model.Empleado?.Id"
                   class="btn btn-outline-warning btn-sm">
                    <i class="fas fa-edit me-1"></i> Editar Datos Básicos
                </a>
            </div>
        </div>
    </div>

    <ul class="nav nav-tabs nav-justified mb-4 border-bottom-0" id="profileTabs" role="tablist">
        <li class="nav-item">
            <button class="nav-link active rounded-top fw-bold" id="general-tab" data-bs-toggle="tab" data-bs-target="#general" type="button">
                <i class="fas fa-address-card me-2"></i>General
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link rounded-top fw-bold" id="vivienda-tab" data-bs-toggle="tab" data-bs-target="#vivienda" type="button">
                <i class="fas fa-map-marker-alt me-2"></i>Vivienda
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link rounded-top fw-bold" id="documentos-tab" data-bs-toggle="tab" data-bs-target="#documentos" type="button">
                <i class="fas fa-file-alt me-2"></i>Documentos
            </button>
        </li>
    </ul>

    <div class="tab-content">
        <!-- ═══════════════════════════════════════════════════ -->
        <!-- TAB GENERAL -->
        <!-- ═══════════════════════════════════════════════════ -->
        <div class="tab-pane fade show active" id="general">
            <div class="d-flex justify-content-end mb-3 gap-2">
                <a href="/Operadores/AltaGeneral/@Model.Empleado?.Id?edit=true"
                   class="btn btn-outline-primary btn-sm">
                    <i class="fas fa-edit me-1"></i> Editar Información General
                </a>
            </div>

            <div class="row g-4">
                <div class="col-lg-8">

                    <!-- Datos de Identidad -->
                    <div class="card shadow-sm border-0 mb-4">
                        <div class="card-header bg-gradient-primary text-white p-3">
                            <h5 class="mb-0"><i class="fas fa-info-circle me-2"></i>Datos de Identidad</h5>
                        </div>
                        <div class="card-body p-4">
                            <div class="info-grid-custom">
                                <div class="info-item-custom">
                                    <label>Email</label>
                                    <span>@(Model.Empleado?.Email ?? "—")</span>
                                </div>
                                <div class="info-item-custom">
                                    <label>Teléfono</label>
                                    <span>@(Model.Empleado?.Telefono ?? "—")</span>
                                </div>
                                <div class="info-item-custom">
                                    <label>RFC</label>
                                    <span>@(Model.Empleado?.Rfc ?? "—")</span>
                                </div>
                                <div class="info-item-custom">
                                    <label>CURP</label>
                                    <span>@(Model.Empleado?.Curp ?? "—")</span>
                                </div>
                                <div class="info-item-custom">
                                    <label>NSS</label>
                                    <span>@(Model.Empleado?.NumSSocial ?? "—")</span>
                                </div>
                                <div class="info-item-custom">
                                    <label>Nacimiento</label>
                                    <span>@(Model.FechaNacimientoFormateada ?? "—")</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- ✅ ACTUALIZADO: Salud y Hábitos con TipoSangre e INFONAVIT -->
                    <div class="card shadow-sm border-0 mb-4">
                        <div class="card-header bg-danger-subtle text-danger p-3 fw-bold">
                            <i class="fas fa-heartbeat me-2"></i>Salud y Hábitos
                        </div>
                        <div class="card-body">
                            <!-- Tipo de Sangre e INFONAVIT en la misma fila -->
                            <div class="d-flex flex-wrap gap-3 mb-3">
                                @if (!string.IsNullOrEmpty(Model.Empleado?.TipoSangre))
                                {
                                    <div class="d-flex align-items-center gap-2 px-3 py-2 rounded"
                                         style="background:#fff0f0; border:1px solid #ffcccc;">
                                        <i class="fas fa-tint text-danger"></i>
                                        <span class="fw-bold text-danger fs-5">@Model.Empleado.TipoSangre</span>
                                        <span class="text-muted small">Tipo de Sangre</span>
                                    </div>
                                }
                                <div class="d-flex align-items-center gap-2 px-3 py-2 rounded
                                     @(Model.Empleado?.CuentaInfonavit == true ? "bg-success bg-opacity-10 border border-success" : "bg-light border")">
                                    <i class="fas fa-home @(Model.Empleado?.CuentaInfonavit == true ? "text-success" : "text-muted")"></i>
                                    <span class="fw-semibold @(Model.Empleado?.CuentaInfonavit == true ? "text-success" : "text-muted")">
                                        INFONAVIT: @(Model.Empleado?.CuentaInfonavit == true ? "Sí" : "No")
                                    </span>
                                </div>
                            </div>
                            <!-- Hábitos y condiciones -->
                            <div class="d-flex flex-wrap gap-3">
                                <div class="badge-custom">Fuma: @BooleanoLabel(Model.Empleado?.Fuma)</div>
                                <div class="badge-custom">Alcohol: @BooleanoLabel(Model.Empleado?.Alcohol)</div>
                                <div class="badge-custom">Diabetes: @BooleanoLabel(Model.Empleado?.Diabetes)</div>
                                <div class="badge-custom">Hipertensión: @BooleanoLabel(Model.Empleado?.Hipertension)</div>
                                <div class="badge-custom">Enf. Crónica: @BooleanoLabel(Model.Empleado?.EnfermedadCronica)</div>
                            </div>
                        </div>
                    </div>

                    <!-- Entorno Social -->
                    <div class="card shadow-sm border-0 mb-4">
                        <div class="card-body">
                            <h5 class="mb-4 text-info fw-bold border-bottom pb-2">
                                <i class="fas fa-graduation-cap me-2"></i>Entorno Social
                            </h5>
                            <div class="row">
                                <div class="col-md-6 border-end">
                                    <p class="mb-2"><strong>Estado Civil:</strong> @FormatearEnum(Model.Empleado?.EstadoCivil)</p>
                                    <p class="mb-2"><strong>Hijos:</strong> @(Model.Empleado?.NumHijos?.ToString() ?? "0")</p>
                                    <p class="mb-0"><strong>Cónyuge:</strong> @(Model.Empleado?.NombreConyuge ?? "—")</p>
                                </div>
                                <div class="col-md-6 ps-md-4">
                                    <p class="mb-2"><strong>Escolaridad:</strong> @FormatearEscolaridad(Model.Empleado?.Escolaridad)</p>
                                    <p class="mb-0"><strong>Nivel Inglés:</strong> @FormatearEnum(Model.Empleado?.NivelIngles)</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Referencias Personales -->
                    <div class="card shadow-sm border-0">
                        <div class="card-header bg-light fw-bold text-dark">
                            <i class="fas fa-users-cog me-2"></i>Referencias Personales
                        </div>
                        <div class="card-body">
                            @{
                                var referencias = Model.Empleado?.ReferenciasPersonales?.Where(r => r.Status == true).ToList() ?? new List<ProyectoRH2025.Models.ReferenciaPersEmpleado>();
                            }
                            @if (referencias.Any())
                            {
                                <div class="table-responsive">
                                    <table class="table table-hover align-middle mb-0 small">
                                        <thead class="table-light">
                                            <tr>
                                                <th>Nombre</th>
                                                <th>Relación</th>
                                                <th>Teléfono</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var refe in referencias)
                                            {
                                                <tr>
                                                    <td class="fw-bold">@refe.NombreReferencia</td>
                                                    <td>@refe.RelacionReferencia</td>
                                                    <td>@refe.TelefonoReferencia</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <p class="text-center text-muted my-3 fst-italic">Sin referencias registradas.</p>
                            }
                        </div>
                    </div>
                </div>

                <!-- Resumen Laboral -->
                <div class="col-lg-4">
                    <div class="card shadow-sm border-0 sticky-top" style="top: 2rem;">
                        <div class="card-header bg-gradient-primary text-white text-center py-3">
                            <h5 class="mb-0">Resumen Laboral</h5>
                        </div>
                        <div class="card-body p-4">
                            <div class="text-center mb-4">
                                <div class="small text-muted mb-1">Número de Reloj</div>
                                <div class="h4 fw-bold text-primary">@(Model.NumeroReloj ?? "—")</div>
                            </div>
                            <hr>
                            <div class="d-grid gap-3">
                                <div class="sidebar-item">
                                    <label>Ingreso</label>
                                    <span>@(Model.FechaIngresoFormateada ?? "—")</span>
                                </div>
                                <div class="sidebar-item">
                                    <label>Reclutamiento</label>
                                    <span>@FormatearEnum(Model.Empleado?.FuenteReclutamiento)</span>
                                </div>
                                <div class="sidebar-item">
                                    <label>Tipo de Empleado</label>
                                    <span>@(Model.TipoEmpleadoDesc ?? "—")</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- TAB VIVIENDA -->
        <!-- ═══════════════════════════════════════════════════ -->
        <div class="tab-pane fade" id="vivienda">
            <div class="d-flex justify-content-end mb-3">
                <a href="/Operadores/AltaVivienda/@Model.Empleado?.Id?edit=true"
                   class="btn btn-outline-primary btn-sm">
                    <i class="fas fa-edit me-1"></i> Editar Información de Vivienda
                </a>
            </div>

            <div class="row g-4">
                @{
                    var domicilios = new[]
                    {
                                new { Tipo = ProyectoRH2025.Models.Enums.TipoDomicilio.Actual, Titulo = "Domicilio Actual", Icon = "fas fa-home", Color = "primary" },
                                new { Tipo = ProyectoRH2025.Models.Enums.TipoDomicilio.Anterior1, Titulo = "Domicilio Anterior 1", Icon = "fas fa-history", Color = "secondary" },
                                new { Tipo = ProyectoRH2025.Models.Enums.TipoDomicilio.Anterior2, Titulo = "Domicilio Anterior 2", Icon = "fas fa-history", Color = "secondary" }
                                };
                }
                @foreach (var domInfo in domicilios)
                {
                    var vivienda = Model.Empleado?.Viviendas?.FirstOrDefault(v => v.TipoDomicilio == domInfo.Tipo);
                    bool tieneDatos = vivienda != null && !string.IsNullOrWhiteSpace(vivienda.Calle ?? vivienda.Ciudad ?? vivienda.Estado);
                    <div class="col-md-6 col-lg-4">
                        <div class="card shadow-sm border-0 h-100">
                            <div class="card-header bg-gradient-@domInfo.Color text-white d-flex align-items-center gap-2">
                                <i class="@domInfo.Icon"></i>
                                <span class="fw-bold">@domInfo.Titulo</span>
                                @if (domInfo.Tipo == ProyectoRH2025.Models.Enums.TipoDomicilio.Actual && tieneDatos && vivienda?.TipoVivienda.HasValue == true)
                                {
                                    var badgeClass = vivienda.TipoVivienda.Value.ToString() switch
                                    {
                                        "Propia" => "bg-success",
                                        "Infonavit" => "bg-primary",
                                        "Renta" => "bg-warning text-dark",
                                        _ => "bg-info text-dark"
                                    };
                                    <span class="badge @badgeClass ms-auto small">@vivienda.TipoVivienda.Value</span>
                                }
                            </div>
                            <div class="card-body">
                                @if (tieneDatos)
                                {
                                    <dl class="row small mb-0">
                                        <dt class="col-5 text-muted">Calle</dt>
                                        <dd class="col-7">@(vivienda.Calle ?? "—")</dd>
                                        <dt class="col-5 text-muted">Ext/Int</dt>
                                        <dd class="col-7">@(vivienda.NoExterior) @(vivienda.NoInterior != null ? $"Int {vivienda.NoInterior}" : "")</dd>
                                        <dt class="col-5 text-muted">Colonia</dt>
                                        <dd class="col-7">@(vivienda.Colonia ?? "—")</dd>
                                        <dt class="col-5 text-muted">Ciudad/CP</dt>
                                        <dd class="col-7">@(vivienda.Ciudad) (@vivienda.codPostal)</dd>
                                        @if (!string.IsNullOrEmpty(vivienda.NoCredito))
                                        {
                                            <dt class="col-5 text-muted text-primary">No. Crédito</dt>
                                            <dd class="col-7 fw-bold">@vivienda.NoCredito</dd>
                                        }
                                    </dl>
                                }
                                else
                                {
                                    <p class="text-center text-muted fst-italic my-4">Sin datos registrados</p>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- TAB DOCUMENTOS -->
        <!-- ═══════════════════════════════════════════════════ -->
        <div class="tab-pane fade" id="documentos" role="tabpanel">
            <div class="d-flex justify-content-end mb-3">
                <a href="/Operadores/AltaDocumentos/@Model.Empleado?.Id?edit=true"
                   class="btn btn-outline-primary btn-sm">
                    <i class="fas fa-edit me-1"></i> Editar Documentos
                </a>
            </div>

            <div class="row g-4">
                <!-- 1 - LICENCIA -->
                <div class="col-lg-6">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-header bg-warning text-dark">
                            <h5 class="mb-0"><i class="fas fa-id-card me-2"></i>Licencia de Conducir</h5>
                        </div>
                        <div class="card-body">
                            @if (Model.Licencia != null && !string.IsNullOrEmpty(Model.Licencia.NumeroLicencia))
                            {
                                <dl class="row mb-0">
                                    <dt class="col-sm-5 text-muted">Número:</dt>
                                    <dd class="col-sm-7 fw-bold">@Model.Licencia.NumeroLicencia</dd>

                                    @if (!string.IsNullOrEmpty(Model.Licencia.Clasificacion))
                                    {
                                        <dt class="col-sm-5 text-muted">Clasificación:</dt>
                                        <dd class="col-sm-7">@Model.Licencia.Clasificacion</dd>
                                    }

                                    @if (Model.Licencia.AnosAntiguedad.HasValue)
                                    {
                                        <dt class="col-sm-5 text-muted">Antigüedad:</dt>
                                        <dd class="col-sm-7">@Model.Licencia.AnosAntiguedad años</dd>
                                    }

                                    @if (Model.Licencia.Vigencia.HasValue)
                                    {
                                        var diasRestantes = (Model.Licencia.Vigencia.Value - DateTime.Today).Days;
                                        var badgeClass = diasRestantes < 30 ? "bg-danger" : diasRestantes < 90 ? "bg-warning text-dark" : "bg-success";
                                        <dt class="col-sm-5 text-muted">Vigencia:</dt>
                                        <dd class="col-sm-7">
                                            @Model.Licencia.Vigencia.Value.ToString("dd/MM/yyyy")
                                            <span class="badge @badgeClass ms-2">@diasRestantes días</span>
                                        </dd>
                                    }
                                </dl>
                            }
                            else
                            {
                                <p class="text-center text-muted my-4 fst-italic">
                                    <i class="fas fa-info-circle me-2"></i>Sin información de licencia
                                </p>
                            }
                        </div>
                    </div>
                </div>

                <!-- 2 - APTO MÉDICO -->
                <div class="col-lg-6">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-header bg-info text-white">
                            <h5 class="mb-0"><i class="fas fa-heartbeat me-2"></i>Apto Médico</h5>
                        </div>
                        <div class="card-body">
                            @if (Model.APTO != null && !string.IsNullOrEmpty(Model.APTO.NumeroExpediente))
                            {
                                <dl class="row mb-0">
                                    <dt class="col-sm-5 text-muted">Exp. Médico:</dt>
                                    <dd class="col-sm-7 fw-bold">@Model.APTO.NumeroExpediente</dd>

                                    @if (Model.APTO.VigenteDesde.HasValue)
                                    {
                                        <dt class="col-sm-5 text-muted">Desde:</dt>
                                        <dd class="col-sm-7">@Model.APTO.VigenteDesde.Value.ToString("dd/MM/yyyy")</dd>
                                    }

                                    @if (Model.APTO.VigenteHasta.HasValue)
                                    {
                                        var diasRestantes = (Model.APTO.VigenteHasta.Value - DateTime.Today).Days;
                                        var badgeClass = diasRestantes < 30 ? "bg-danger" : diasRestantes < 90 ? "bg-warning text-dark" : "bg-success";
                                        <dt class="col-sm-5 text-muted">Vigencia:</dt>
                                        <dd class="col-sm-7">
                                            @Model.APTO.VigenteHasta.Value.ToString("dd/MM/yyyy")
                                            <span class="badge @badgeClass ms-2">@diasRestantes días</span>
                                        </dd>
                                    }
                                </dl>
                            }
                            else
                            {
                                <p class="text-center text-muted my-4 fst-italic">
                                    <i class="fas fa-info-circle me-2"></i>Sin información de apto médico
                                </p>
                            }
                        </div>
                    </div>
                </div>

                <!-- 5 - ANTECEDENTES NO PENALES -->
                <div class="col-lg-6">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-header bg-success text-white">
                            <h5 class="mb-0"><i class="fas fa-file-contract me-2"></i>Antecedentes No Penales</h5>
                        </div>
                        <div class="card-body">
                            @if (Model.Antecedentes != null && Model.Antecedentes.FechaAntecedentes.HasValue)
                            {
                                <dl class="row mb-0">
                                    <dt class="col-sm-5 text-muted">Fecha:</dt>
                                    <dd class="col-sm-7 fw-bold">@Model.Antecedentes.FechaAntecedentes.Value.ToString("dd/MM/yyyy")</dd>
                                    @{
                                        var diasDesdeAnt = (DateTime.Today - Model.Antecedentes.FechaAntecedentes.Value).Days;
                                        var mesesDesdeAnt = diasDesdeAnt / 30;
                                    }
                                    <dt class="col-sm-5 text-muted">Antigüedad:</dt>
                                    <dd class="col-sm-7">
                                        <span class="badge bg-secondary">Hace @mesesDesdeAnt meses</span>
                                    </dd>
                                </dl>
                            }
                            else
                            {
                                <p class="text-center text-muted my-4 fst-italic">
                                    <i class="fas fa-info-circle me-2"></i>Sin información de antecedentes
                                </p>
                            }
                        </div>
                    </div>
                </div>

                <!-- 6 - ESTUDIO SOCIOECONÓMICO -->
                <div class="col-lg-6">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0"><i class="fas fa-chart-line me-2"></i>Estudio Socioeconómico</h5>
                        </div>
                        <div class="card-body">
                            @if (Model.EstudioSocio != null && Model.EstudioSocio.FechaEstudio.HasValue)
                            {
                                <dl class="row mb-0">
                                    <dt class="col-sm-5 text-muted">Fecha:</dt>
                                    <dd class="col-sm-7 fw-bold">@Model.EstudioSocio.FechaEstudio.Value.ToString("dd/MM/yyyy")</dd>
                                    @{
                                        var diasDesdeEst = (DateTime.Today - Model.EstudioSocio.FechaEstudio.Value).Days;
                                        var mesesDesdeEst = diasDesdeEst / 30;
                                    }
                                    <dt class="col-sm-5 text-muted">Antigüedad:</dt>
                                    <dd class="col-sm-7">
                                        <span class="badge bg-secondary">Hace @mesesDesdeEst meses</span>
                                    </dd>
                                </dl>
                            }
                            else
                            {
                                <p class="text-center text-muted my-4 fst-italic">
                                    <i class="fas fa-info-circle me-2"></i>Sin información de estudio socioeconómico
                                </p>
                            }
                        </div>
                    </div>
                </div>

                <!-- 7 - EVALUACIÓN DE MANEJO -->
                <div class="col-lg-12">
                    <div class="card shadow-sm border-0">
                        <div class="card-header bg-dark text-white">
                            <h5 class="mb-0"><i class="fas fa-clipboard-check me-2"></i>Evaluación de Manejo</h5>
                        </div>
                        <div class="card-body">
                            @if (Model.Evaluacion != null && Model.Evaluacion.FechaEvaluacion.HasValue)
                            {
                                <div class="row">
                                    <div class="col-md-6">
                                        <dl class="row">
                                            <dt class="col-sm-5 text-muted">Fecha:</dt>
                                            <dd class="col-sm-7 fw-bold">@Model.Evaluacion.FechaEvaluacion.Value.ToString("dd/MM/yyyy")</dd>

                                            @if (!string.IsNullOrEmpty(Model.Evaluacion.Proposito))
                                            {
                                                <dt class="col-sm-5 text-muted">Propósito:</dt>
                                                <dd class="col-sm-7">@Model.Evaluacion.Proposito</dd>
                                            }

                                            @if (Model.Evaluacion.Nota.HasValue)
                                            {
                                                var colorNota = Model.Evaluacion.Nota.Value >= 80 ? "success" :
                                                Model.Evaluacion.Nota.Value >= 60 ? "warning" : "danger";
                                                <dt class="col-sm-5 text-muted">Calificación:</dt>
                                                <dd class="col-sm-7">
                                                    <span class="badge bg-@colorNota fs-6">@Model.Evaluacion.Nota.Value pts</span>
                                                </dd>
                                            }
                                        </dl>
                                    </div>
                                    <div class="col-md-6">
                                        <dl class="row">
                                            @if (!string.IsNullOrEmpty(Model.Evaluacion.NombreEvaluador))
                                            {
                                                <dt class="col-sm-5 text-muted">Evaluador:</dt>
                                                <dd class="col-sm-7">@Model.Evaluacion.NombreEvaluador</dd>
                                            }

                                            @if (!string.IsNullOrEmpty(Model.Evaluacion.Comentarios))
                                            {
