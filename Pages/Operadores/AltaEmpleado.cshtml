@page
@model ProyectoRH2025.Pages.Operadores.AltaEmpleadoModel
@{
    ViewData["Title"] = "Alta de Empleado";
}

<style>
    :root {
        --primary-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        --success-gradient: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
        --card-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
        --border-radius: 15px;
    }

    .form-header {
        background: var(--primary-gradient);
        color: white;
        border-radius: var(--border-radius);
        padding: 2rem;
        margin-bottom: 2rem;
        box-shadow: var(--card-shadow);
    }

        .form-header h1 {
            font-size: 2rem;
            font-weight: 700;
            margin: 0;
        }

        .form-header p {
            margin: 0.5rem 0 0 0;
            opacity: 0.9;
        }

    .back-btn {
        background: rgba(255, 255, 255, 0.9);
        border: none;
        border-radius: 50px;
        padding: 0.75rem 1.5rem;
        font-weight: 600;
        color: #667eea;
        text-decoration: none;
        transition: all 0.3s ease;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
        margin-bottom: 1rem;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }

        .back-btn:hover {
            transform: translateX(-5px);
            color: #667eea;
            text-decoration: none;
        }

    .progress-bar {
        height: 6px;
        background: #e2e8f0;
        border-radius: 3px;
        overflow: hidden;
        margin-bottom: 1rem;
    }

    .progress-fill {
        height: 100%;
        background: var(--primary-gradient);
        width: 0%;
        transition: width 0.5s ease;
    }

    .form-steps {
        display: flex;
        justify-content: center;
        gap: 2rem;
        margin-bottom: 2rem;
    }

    .step {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: #e2e8f0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        color: #718096;
        transition: all 0.3s ease;
    }

        .step.active {
            background: var(--primary-gradient);
            color: white;
        }

        .step.completed {
            background: var(--success-gradient);
            color: white;
        }

    .card {
        border: none;
        border-radius: var(--border-radius);
        box-shadow: var(--card-shadow);
    }

    .card-body {
        padding: 2rem;
    }

    .form-label {
        font-weight: 600;
        color: #4a5568;
        font-size: 0.9rem;
        margin-bottom: 0.5rem;
    }

    .required-indicator {
        color: #f56565;
    }

    .form-control {
        border: 2px solid #e2e8f0;
        border-radius: 12px;
        padding: 0.75rem;
        transition: all 0.3s ease;
    }

        .form-control:focus {
            border-color: #667eea;
            box-shadow: 0 0 0 0.2rem rgba(102, 126, 234, 0.25);
            outline: none;
        }

        .form-control:disabled {
            background-color: #f7fafc;
            cursor: not-allowed;
            opacity: 0.6;
        }

        .form-control.is-invalid {
            border-color: #f56565 !important;
            background-color: rgba(245, 101, 101, 0.1);
        }

    .photo-upload {
        background: rgba(102, 126, 234, 0.05);
        border: 2px dashed #667eea;
        border-radius: 15px;
        padding: 2rem;
        text-align: center;
        cursor: pointer;
        min-height: 250px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
    }

        .photo-upload:hover {
            background: rgba(102, 126, 234, 0.15);
            border-color: #764ba2;
        }

    .photo-preview {
        max-width: 100%;
        max-height: 300px;
        border-radius: 15px;
        object-fit: cover;
    }

    .btn-primary {
        background: var(--primary-gradient);
        border: none;
        border-radius: 50px;
        padding: 0.75rem 2rem;
        font-weight: 600;
        color: white;
        transition: all 0.3s ease;
    }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(102, 126, 234, 0.4);
        }

    .loading-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(255, 255, 255, 0.9);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 9999;
        flex-direction: column;
    }

    .loading-spinner {
        width: 50px;
        height: 50px;
        border: 4px solid #e2e8f0;
        border-top: 4px solid #667eea;
        border-radius: 50%;
        animation: spin 1s linear infinite;
    }

    @@keyframes spin {
        100% {
            transform: rotate(360deg);
        }
    }

    .alert-success {
        background: linear-gradient(135deg, rgba(72, 187, 120, 0.1) 0%, rgba(56, 178, 172, 0.1) 100%);
        color: #2f855a;
        border: 2px solid #48bb78;
        border-radius: 15px;
        padding: 1.5rem;
        box-shadow: 0 5px 15px rgba(72, 187, 120, 0.2);
    }

        .alert-success .alert-heading {
            color: #2f855a;
            font-weight: 700;
            margin-bottom: 1rem;
        }

        .alert-success hr {
            border-color: #48bb78;
            opacity: 0.3;
            margin: 1rem 0;
        }

        .alert-success .btn-success {
            background: linear-gradient(135deg, #48bb78 0%, #38b2ac 100%);
            border: none;
            box-shadow: 0 4px 10px rgba(72, 187, 120, 0.3);
            border-radius: 50px;
            padding: 0.5rem 1.5rem;
            font-weight: 600;
        }

            .alert-success .btn-success:hover {
                transform: translateY(-2px);
                box-shadow: 0 6px 15px rgba(72, 187, 120, 0.4);
            }

    .alert-danger {
        background: rgba(245, 101, 101, 0.1);
        color: #c53030;
        border: 2px solid #f56565;
        border-radius: 15px;
        padding: 1.5rem;
        box-shadow: 0 5px 15px rgba(245, 101, 101, 0.2);
    }

        .alert-danger .alert-heading {
            margin-bottom: 0.5rem;
            color: #c53030;
        }

    h5 {
        margin-bottom: 1rem;
        color: #2d3748;
    }
</style>

<div class="loading-overlay" id="loadingOverlay">
    <div class="loading-spinner"></div>
    <p class="mt-2">Guardando empleado...</p>
</div>

<div class="container-fluid">
    <a class="back-btn" asp-page="./Buscar">
        <i class="fas fa-arrow-left"></i> Regresar a la lista
    </a>

    <div class="form-header">
        <h1><i class="fas fa-user-plus me-3"></i>Nuevo Empleado</h1>
        <p>Complete todos los campos requeridos para registrar un nuevo empleado</p>
    </div>

    <div class="progress-container mb-3">
        <div class="progress-bar">
            <div class="progress-fill" id="progressFill"></div>
        </div>
        <div class="form-steps">
            <div class="step active" id="step1">1</div>
            <div class="step" id="step2">2</div>
            <div class="step" id="step3">3</div>
            <div class="step" id="step4">4</div>
        </div>
    </div>

    <!-- MENSAJES -->
    @if (!string.IsNullOrEmpty(Model.Mensaje))
    {
        var partes = Model.Mensaje.Split('|');
        var esExito = partes[0].StartsWith("✅");

        <div class="alert @(esExito ? "alert-success" : "alert-danger") alert-dismissible fade show" role="alert" id="mensajeAlert">
            @if (esExito)
            {
                <h5 class="alert-heading">
                    <i class="fas fa-check-circle me-2"></i>¡Registro Exitoso!
                </h5>
                <hr>
                <p class="mb-1"><strong>Empleado:</strong> @partes[1]</p>
                <p class="mb-1"><strong>@partes[2]</strong></p>
                <p class="mb-1"><strong>@partes[3]</strong></p>
                <p class="mb-3"><strong>@partes[4]</strong></p>
                <button type="button" class="btn btn-success" onclick="limpiarFormulario()">
                    <i class="fas fa-plus me-2"></i>Registrar Otro Empleado
                </button>
            }
            else
            {
                <h5 class="alert-heading">
                    <i class="fas fa-exclamation-triangle me-2"></i>Error
                </h5>
                @foreach (var parte in partes)
                {
                    <p class="mb-1">@parte</p>
                }
            }
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card">
        <div class="card-body">
            <form method="post" enctype="multipart/form-data" id="employeeForm">
                <div class="row">
                    <div class="col-md-8">
                        <!-- Información Personal -->
                        <h5><i class="fas fa-user me-2"></i>Información Personal</h5>
                        <div class="row mb-3">
                            <div class="col-md-3">
                                <label class="form-label">Reloj <span class="required-indicator">*</span></label>
                                <input asp-for="Empleado.Reloj" class="form-control" required />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Nombres <span class="required-indicator">*</span></label>
                                <input asp-for="Empleado.Names" class="form-control" required />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Apellido <span class="required-indicator">*</span></label>
                                <input asp-for="Empleado.Apellido" class="form-control" required />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Segundo Apellido <span class="required-indicator">*</span></label>
                                <input asp-for="Empleado.Apellido2" class="form-control" required />
                            </div>
                        </div>

                        <!-- Información de Contacto -->
                        <h5 class="mt-4"><i class="fas fa-address-book me-2"></i>Información de Contacto</h5>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label">Correo <span class="required-indicator">*</span></label>
                                <input asp-for="Empleado.Email" class="form-control" type="email" required />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Teléfono <span class="required-indicator">*</span></label>
                                <input asp-for="Empleado.Telefono" class="form-control" required />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Tel. Emergencia <span class="required-indicator">*</span></label>
                                <input asp-for="Empleado.TelEmergencia" class="form-control" required />
                            </div>
                        </div>

                        <!-- Documentos Oficiales -->
                        <h5 class="mt-4"><i class="fas fa-id-card me-2"></i>Documentos Oficiales</h5>
                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label class="form-label">RFC <span class="required-indicator">*</span></label>
                                <input asp-for="Empleado.Rfc" class="form-control" required />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">CURP <span class="required-indicator">*</span></label>
                                <input asp-for="Empleado.Curp" class="form-control" required />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">NSS <span class="required-indicator">*</span></label>
                                <input asp-for="Empleado.NumSSocial" class="form-control" required />
                            </div>
                        </div>

                        <!-- Información Laboral -->
                        <h5 class="mt-4"><i class="fas fa-briefcase me-2"></i>Información Laboral</h5>
                        <div class="row mb-3">
                            <div class="col-md-3">
                                <label class="form-label">
                                    <i class="fas fa-user-tag"></i>
                                    Tipo de Empleado <span class="required-indicator">*</span>
                                </label>
                                <select id="tipoEmpleadoSelect" class="form-control" required>
                                    <option value="">Seleccionar...</option>
                                    <option value="1">Operativo</option>
                                    <option value="2">Administrativo</option>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Fecha de Ingreso <span class="required-indicator">*</span></label>
                                <input asp-for="Empleado.Fingreso" class="form-control" type="date" required />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Puesto <span class="required-indicator">*</span></label>
                                <select name="PuestoNombre" id="PuestoNombre" class="form-control" required disabled>
                                    <option value="">Primero selecciona tipo...</option>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Empresa <span class="required-indicator">*</span></label>
                                <select asp-for="Empleado.CodClientes" class="form-control" required>
                                    <option value="">Seleccionar...</option>
                                    <option value="2">AKNA</option>
                                    <option value="1">STIL</option>
                                </select>
                            </div>
                        </div>

                        <!-- Información Adicional -->
                        <h5 class="mt-4"><i class="fas fa-info-circle me-2"></i>Información Adicional</h5>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label">Fecha de Nacimiento <span class="required-indicator">*</span></label>
                                <input asp-for="Empleado.Fnacimiento" class="form-control" type="date" required />
                                <small class="text-muted">Debe ser mayor de 18 años</small>
                            </div>
                        </div>
                    </div>

                    <!-- Fotografía -->
                    <div class="col-md-4">
                        <h5><i class="fas fa-camera me-2"></i>Fotografía <span class="required-indicator">*</span></h5>
                        <div class="photo-upload" onclick="document.getElementById('photoInput').click();">
                            <input type="file" name="FotoArchivo" id="photoInput" accept="image/*" style="display: none;" onchange="previewFoto(event)" />
                            <div id="uploadPlaceholder">
                                <i class="fas fa-camera fa-3x text-primary mb-3"></i>
                                <h5>Subir Fotografía</h5>
                                <p class="text-muted small mb-1">Haz clic aquí</p>
                                <p class="text-muted small">JPG, PNG máx. 5MB</p>
                            </div>
                            <img id="fotoPreview" class="photo-preview" style="display: none;" alt="Vista previa" />
                        </div>
                    </div>
                </div>

                <div class="text-center mt-4">
                    <button type="submit" class="btn btn-primary btn-lg px-5" id="submitBtn">
                        <i class="fas fa-save me-2"></i>Guardar Empleado
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Variables globales
        let progressFill;
        let photoInput;
        let inputs;

        // ========== DATOS DE PUESTOS CON SU TIPO ==========
        const todosLosPuestos = [
            @foreach (var puesto in Model.Puestos)
            {
                    var puestoLimpio = puesto.Puesto?.Replace("\r", "").Replace("\n", "").Trim() ?? "";
                    <text>{ nombre: '@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(puestoLimpio))', tipo: @puesto.idtipempleado },</text>
            }
        ];

        console.log('📋 Puestos cargados:', todosLosPuestos.length);

        // ========== PREVIEW DE FOTO ==========
        function previewFoto(event) {
            const input = event.target;
            const preview = document.getElementById('fotoPreview');
            const placeholder = document.getElementById('uploadPlaceholder');

            console.log('📸 Archivo seleccionado');

            if (input.files && input.files[0]) {
                const file = input.files[0];
                console.log('📸 Nombre:', file.name, 'Tipo:', file.type, 'Tamaño:', file.size);

                if (!file.type.startsWith('image/')) {
                    alert('⚠️ Por favor selecciona una imagen válida (JPG, PNG)');
                    input.value = '';
                    return;
                }

                if (file.size > 5 * 1024 * 1024) {
                    alert('⚠️ La imagen no debe superar los 5MB');
                    input.value = '';
                    return;
                }

                const reader = new FileReader();
                reader.onload = function(e) {
                    console.log('✅ Imagen cargada correctamente');
                    preview.src = e.target.result;
                    preview.style.display = 'block';
                    placeholder.style.display = 'none';
                    if (typeof updateProgress === 'function') {
                        updateProgress();
                    }
                };
                reader.onerror = function() {
                    console.error('❌ Error al cargar la imagen');
                    alert('Error al cargar la imagen');
                };
                reader.readAsDataURL(file);
            }
        }

        // ========== FUNCIÓN DE PROGRESO ==========
        function updateProgress() {
            if (!progressFill || !photoInput || !inputs) return;

            let valid = 0;
            inputs.forEach(input => {
                if (input.value && input.checkValidity()) valid++;
            });

            if (photoInput.files && photoInput.files.length > 0) valid++;

            const percent = (valid / (inputs.length + 1)) * 100;
            progressFill.style.width = percent + '%';

            const step1 = document.getElementById('step1');
            const step2 = document.getElementById('step2');
            const step3 = document.getElementById('step3');
            const step4 = document.getElementById('step4');

            if (step1) step1.className = percent >= 25 ? 'step completed' : 'step active';
            if (step2) step2.className = percent >= 50 ? 'step completed' : (percent >= 25 ? 'step active' : 'step');
            if (step3) step3.className = percent >= 75 ? 'step completed' : (percent >= 50 ? 'step active' : 'step');
            if (step4) step4.className = percent === 100 ? 'step completed' : (percent >= 75 ? 'step active' : 'step');
        }

        // ========== FUNCIÓN PARA LIMPIAR FORMULARIO ==========
        function limpiarFormulario() {
            const form = document.getElementById('employeeForm');
            const mensajeAlert = document.getElementById('mensajeAlert');

            console.log('🧹 Limpiando formulario...');

            // Limpiar todos los inputs
            form.reset();

            // Limpiar foto
            const photoPreview = document.getElementById('fotoPreview');
            const uploadPlaceholder = document.getElementById('uploadPlaceholder');
            if (photoPreview) photoPreview.style.display = 'none';
            if (uploadPlaceholder) uploadPlaceholder.style.display = 'block';

            // Deshabilitar puesto
            const puestoSelect = document.getElementById('PuestoNombre');
            if (puestoSelect) {
                puestoSelect.disabled = true;
                puestoSelect.innerHTML = '<option value="">Primero selecciona tipo...</option>';
            }

            // Remover clases de validación
            const inputsWithValidation = form.querySelectorAll('.is-invalid, .is-valid');
            inputsWithValidation.forEach(input => {
                input.classList.remove('is-invalid', 'is-valid');
            });

            // Ocultar mensaje
            if (mensajeAlert) {
                mensajeAlert.style.display = 'none';
            }

            // Resetear progreso
            if (progressFill) progressFill.style.width = '0%';

            // Resetear steps
            const steps = document.querySelectorAll('.step');
            steps.forEach((step, index) => {
                if (index === 0) {
                    step.className = 'step active';
                } else {
                    step.className = 'step';
                }
            });

            // Scroll al inicio
            window.scrollTo({ top: 0, behavior: 'smooth' });

            // Habilitar botón submit
            const submitBtn = document.getElementById('submitBtn');
            if (submitBtn) {
                submitBtn.disabled = false;
                submitBtn.innerHTML = '<i class="fas fa-save me-2"></i>Guardar Empleado';
            }

            // Ocultar loading
            const loadingOverlay = document.getElementById('loadingOverlay');
            if (loadingOverlay) loadingOverlay.style.display = 'none';

            console.log('✅ Formulario limpiado');
        }

        document.addEventListener('DOMContentLoaded', function() {
            const form = document.getElementById('employeeForm');
            progressFill = document.getElementById('progressFill');
            photoInput = document.getElementById('photoInput');
            inputs = form.querySelectorAll('input[required], select[required]');

            const tipoEmpleadoSelect = document.getElementById('tipoEmpleadoSelect');
            const puestoSelect = document.getElementById('PuestoNombre');

            console.log('✅ Sistema inicializado');
            console.log('📋 Inputs encontrados:', inputs.length);

            // ========== FILTRAR PUESTOS POR TIPO ==========
            tipoEmpleadoSelect.addEventListener('change', function() {
                const tipoSeleccionado = parseInt(this.value);

                console.log('🔍 Tipo seleccionado:', tipoSeleccionado);

                puestoSelect.innerHTML = '<option value="">Seleccionar puesto...</option>';

                if (tipoSeleccionado) {
                    puestoSelect.disabled = false;

                    const puestosFiltrados = todosLosPuestos.filter(p => p.tipo === tipoSeleccionado);

                    console.log(`✅ ${puestosFiltrados.length} puestos encontrados para tipo ${tipoSeleccionado === 1 ? 'Operativo' : 'Administrativo'}`);

                    if (puestosFiltrados.length === 0) {
                        console.warn('⚠️ No se encontraron puestos para este tipo');
                    } else {
                        puestosFiltrados.forEach(puesto => {
                            const option = document.createElement('option');
                            option.value = puesto.nombre;
                            option.textContent = puesto.nombre;
                            puestoSelect.appendChild(option);
                        });
                    }
                } else {
                    puestoSelect.disabled = true;
                    puestoSelect.innerHTML = '<option value="">Primero selecciona tipo...</option>';
                }

                updateProgress();
            });

            // ========== EVENT LISTENERS PARA PROGRESO ==========
            inputs.forEach(i => {
                i.addEventListener('input', updateProgress);
                i.addEventListener('change', updateProgress);
            });

            // ========== VALIDACIONES ==========
            const rfcInput = document.querySelector('input[name="Empleado.Rfc"]');
            const curpInput = document.querySelector('input[name="Empleado.Curp"]');

            if (rfcInput) rfcInput.addEventListener('input', function() { this.value = this.value.toUpperCase(); });
            if (curpInput) curpInput.addEventListener('input', function() { this.value = this.value.toUpperCase(); });

            const fechaNac = document.querySelector('input[name="Empleado.Fnacimiento"]');
            if (fechaNac) {
                const hace18 = new Date();
                hace18.setFullYear(hace18.getFullYear() - 18);
                fechaNac.max = hace18.toISOString().split('T')[0];

                fechaNac.addEventListener('change', function() {
                    const fecha = new Date(this.value);
                    const hoy = new Date();
                    let edad = hoy.getFullYear() - fecha.getFullYear();
                    const m = hoy.getMonth() - fecha.getMonth();
                    if (m < 0 || (m === 0 && hoy.getDate() < fecha.getDate())) edad--;

                    if (edad < 18) {
                        alert('⚠️ El empleado debe ser mayor de 18 años');
                        this.value = '';
                    }
                });
            }

            // ========== SUBMIT ==========
            form.addEventListener('submit', function(e) {
                console.log('🚀 Submit event triggered');

                if (!photoInput.files || photoInput.files.length === 0) {
                    e.preventDefault();
                    alert('⚠️ Por favor adjunta una fotografía');
                    return false;
                }

                console.log('✅ Foto adjunta:', photoInput.files[0].name);

                if (!tipoEmpleadoSelect.value) {
                    e.preventDefault();
                    alert('⚠️ Por favor selecciona el tipo de empleado');
                    tipoEmpleadoSelect.classList.add('is-invalid');
                    return false;
                }

                console.log('✅ Tipo de empleado:', tipoEmpleadoSelect.value);

                if (!puestoSelect || !puestoSelect.value) {
                    e.preventDefault();
                    alert('⚠️ Por favor selecciona un puesto');
                    if (puestoSelect) puestoSelect.classList.add('is-invalid');
                    return false;
                }

                console.log('✅ Puesto seleccionado:', puestoSelect.value);

                const empresaSelect = document.querySelector('select[name="Empleado.CodClientes"]');
                if (!empresaSelect || !empresaSelect.value) {
                    e.preventDefault();
                    alert('⚠️ Por favor selecciona una empresa');
                    if (empresaSelect) empresaSelect.classList.add('is-invalid');
                    return false;
                }

                console.log('✅ Empresa seleccionada:', empresaSelect.value);

                let valid = true;
                let camposInvalidos = [];

                inputs.forEach(input => {
                    if (!input.value || !input.checkValidity()) {
                        valid = false;
                        camposInvalidos.push(input.name || input.id);
                        input.classList.add('is-invalid');
                    }
                });

                if (!valid) {
                    e.preventDefault();
                    alert('⚠️ Por favor complete todos los campos obligatorios');
                    return false;
                }

                console.log('✅✅✅ FORMULARIO VÁLIDO - ENVIANDO...');

                const loadingOverlay = document.getElementById('loadingOverlay');
                const submitBtn = document.getElementById('submitBtn');

                if (loadingOverlay) loadingOverlay.style.display = 'flex';
                if (submitBtn) {
                    submitBtn.disabled = true;
                    submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Guardando...';
                }

                return true;
            });

            // Auto-scroll al mensaje de éxito
            const mensajeAlert = document.getElementById('mensajeAlert');
            if (mensajeAlert && mensajeAlert.classList.contains('alert-success')) {
                setTimeout(() => {
                    mensajeAlert.scrollIntoView({ behavior: 'smooth', block: 'center' });
                }, 500);
            }

            updateProgress();
        });
    </script>
}